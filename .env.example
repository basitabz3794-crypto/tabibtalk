# Copy this file to .env and fill in real values before deploying.
# This file is committed to git, so it must only ever contain PLACEHOLDERS.
# Real values belong in .env, which is gitignored.

# ---- Server ----
PORT=3000
SESSION_SECRET=replace-this-with-a-long-random-string

# ---- PayPal manual payment details, for international users (shown to users at checkout) ----
# All PayPal payments are confirmed manually (same as InstaPay/UPI below) —
# no PayPal API keys are needed for this. Just your PayPal email and, optionally,
# your PayPal.me link so users have a one-click way to pay you.
# Leave blank to have the Plans page show "not configured yet" for PayPal.
PAYPAL_EMAIL=
PAYPAL_ME_LINK=

# ---- InstaPay manual payment details (shown to users at checkout) ----
INSTAPAY_IPA=your-instapay-address@instapay
INSTAPAY_PHONE=+20000000000

# ---- UPI manual payment details, for Indian users (shown to users at checkout) ----
UPI_ID=your-upi-id@bank
UPI_PAYEE_NAME=Your Payee Name

# ---- Admin panel access ----
# Use a long random string. Anyone with this value can read every user's data.
ADMIN_KEY=replace-this-with-a-long-random-string

# ---- App ----
APP_URL=http://localhost:3000

# ---- Firebase (client SDK — safe to expose publicly) ----
# From Firebase Console → Project settings → Your apps → SDK setup and configuration.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=

# ---- Firebase Admin SDK (server-side — SECRET, never commit) ----
# From Firebase Console → Project settings → Service accounts → Generate new private key.
# Paste the whole downloaded JSON on one line, wrapped in single quotes.
FIREBASE_SERVICE_ACCOUNT_JSON=
